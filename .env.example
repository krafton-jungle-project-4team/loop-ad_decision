# Loop-Ad Decision API local environment example.
# Copy this to .env only for local development and fill real values locally.
# The API loads .env automatically when it starts from this directory.
# Do not commit real secrets. Production values are injected by infra.

LOOPAD_ENV=dev
LOOPAD_SERVICE_ID=decision-api
PORT=8080

# Internal/admin API auth for POST /internal/jobs/daily-decision/run.
LOOPAD_INTERNAL_API_KEY=replace-with-local-internal-key

# Aurora PostgreSQL connection.
LOOPAD_AURORA_HOST=localhost
LOOPAD_AURORA_PORT=15432
LOOPAD_AURORA_DATABASE=loopad
LOOPAD_AURORA_USERNAME=loopad
LOOPAD_AURORA_PASSWORD=loopad

# ClickHouse connection.
LOOPAD_CLICKHOUSE_URL=http://localhost:18123
LOOPAD_CLICKHOUSE_DATABASE=loopad
LOOPAD_CLICKHOUSE_USERNAME=loopad_app
LOOPAD_CLICKHOUSE_PASSWORD=loopad_local_password

# Generated asset storage and content generation.
LOOPAD_DATA_STORAGE_BUCKET=local-data-storage-bucket
LOOPAD_GENAI_ASSETS_BASE_PREFIX=genai/
LOOPAD_GENAI_ASSETS_PUBLIC_BASE_URL=https://gen-ai.asset.dev.loop-ad.org
LOOPAD_GENAI_SOURCE_MANIFEST_PREFIX=genai-source/
LOOPAD_OPENAI_API_KEY=replace-with-local-openai-key
LOOPAD_OPENAI_CONTENT_MODEL=gpt-4o-mini
LOOPAD_GEMINI_API_KEY=replace-with-local-gemini-key

# Optional durable Generation worker settings.
GENERATION_WORKER_MAX_CONCURRENCY=2
GENERATION_POLL_INTERVAL_SECONDS=1
GENERATION_IDLE_POLL_INTERVAL_SECONDS=30
GENERATION_LEASE_SECONDS=180
GENERATION_HEARTBEAT_SECONDS=30
GENERATION_MAX_RETRIES=3
GENERATION_RETRY_BACKOFF_SECONDS=60,300,900
GENERATION_PROVIDER_TIMEOUT_SECONDS=30
GENERATION_DB_OPERATION_TIMEOUT_SECONDS=5
GENERATION_SHUTDOWN_GRACE_SECONDS=20

# Optional compatibility with the older project-local manual API token name.
# Prefer LOOPAD_INTERNAL_API_KEY and X-Loop-Ad-Internal-Key.
# AI_DECISION_ADMIN_TOKEN=replace-only-if-needed
