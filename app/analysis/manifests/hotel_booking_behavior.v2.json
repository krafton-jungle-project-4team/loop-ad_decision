{
  "schema_version": "hotel_booking_behavior.v2",
  "vector_version": "hotel_behavior.v2",
  "vector_dim": 64,
  "missing_value_policy": "zero_means_observed_absence_or_unavailable; never_impute_from_text_or_demographics",
  "normalization": "l2_after_feature_transforms",
  "query_block_normalization": "l2_per_active_block_then_weight_then_global_l2",
  "window_policy": {
    "type": "bounded_request_window",
    "minimum_days": 1,
    "maximum_days": 3650,
    "end_exclusive": true
  },
  "destination_alias_version": "hotel_destination_alias.v1",
  "canonical_destination_id_patterns": ["^[0-9]{1,20}$"],
  "destination_aliases": {
    "jeju": ["jeju", "jeju-do", "jeju island", "제주", "제주도"],
    "seoul": ["seoul", "서울", "서울특별시"],
    "busan": ["busan", "부산", "부산광역시"],
    "gangneung": ["gangneung", "강릉", "강릉시"],
    "gyeongju": ["gyeongju", "경주", "경주시"],
    "incheon": ["incheon", "인천", "인천광역시"],
    "sokcho": ["sokcho", "속초", "속초시"],
    "yeosu": ["yeosu", "여수", "여수시"]
  },
  "blocks": {
    "funnel": [0, 15],
    "destination": [16, 31],
    "timing": [32, 39],
    "benefit": [40, 47],
    "promotion_response": [48, 55],
    "derived": [56, 63]
  },
  "candidate_block_weights": {
    "intent_matched": {"funnel": 0.35, "destination": 0.35, "timing": 0.15, "derived": 0.15},
    "target_destination_affinity": {"destination": 0.60, "funnel": 0.20, "derived": 0.20},
    "funnel_recovery": {"funnel": 0.55, "destination": 0.25, "derived": 0.20},
    "benefit_value_seeker": {"benefit": 0.50, "destination": 0.20, "funnel": 0.10, "derived": 0.20},
    "promotion_responsive": {"promotion_response": 0.65, "funnel": 0.10, "derived": 0.25},
    "general_destination_explorer": {"destination": 0.30, "funnel": 0.20, "derived": 0.50}
  },
  "candidate_query_dimensions": {
    "intent_matched": ["hotel_search_intensity", "hotel_detail_view_intensity", "hotel_consideration_intensity", "has_hotel_interest", "engagement_composite"],
    "target_destination_affinity": ["hotel_search_intensity", "hotel_detail_view_intensity", "hotel_consideration_intensity", "single_destination_concentration", "engagement_composite"],
    "funnel_recovery": ["hotel_detail_view_intensity", "booking_start_intensity", "booking_start_without_complete", "has_booking_abandonment", "engagement_composite"],
    "benefit_value_seeker": ["hotel_search_intensity", "deal_interest_intensity", "price_interest_intensity", "free_cancellation_interest", "breakfast_interest", "benefit_breadth", "has_benefit_interest"],
    "promotion_responsive": ["promotion_impression_intensity", "promotion_click_intensity", "campaign_redirect_intensity", "campaign_landing_intensity", "promotion_click_rate", "campaign_landing_rate", "promotion_response_intensity", "has_promotion_response"],
    "general_destination_explorer": ["hotel_search_intensity", "hotel_click_intensity", "hotel_detail_view_intensity", "hotel_consideration_intensity", "destination_breadth", "engagement_composite"]
  },
  "candidate_hard_predicates": {
    "intent_matched": ["hotel_product_interest"],
    "target_destination_affinity": ["target_destination_affinity", "hotel_product_interest"],
    "funnel_recovery": ["booking_start_without_complete"],
    "benefit_value_seeker": ["benefit_interest"],
    "promotion_responsive": ["promotion_response"],
    "general_destination_explorer": ["general_destination_exploration"]
  },
  "season_query_dimensions": {
    "spring": "spring_checkin_share",
    "summer": "summer_checkin_share",
    "fall": "fall_checkin_share",
    "autumn": "fall_checkin_share",
    "winter": "winter_checkin_share"
  },
  "intent_benefit_query_dimensions": {
    "discount": ["deal_interest_intensity", "price_interest_intensity"],
    "early_booking": ["deal_interest_intensity", "price_interest_intensity"],
    "free_cancellation": ["free_cancellation_interest"],
    "breakfast_included": ["breakfast_interest"]
  },
  "dimensions": [
    {"index": 0, "name": "page_view_intensity", "block": "funnel", "raw_calculation": "bounded_log_intensity(page_view_count,event_count)", "query_enabled": false},
    {"index": 1, "name": "hotel_search_intensity", "block": "funnel", "raw_calculation": "bounded_log_intensity(hotel_search_count,event_count)", "query_enabled": true},
    {"index": 2, "name": "hotel_click_intensity", "block": "funnel", "raw_calculation": "bounded_log_intensity(hotel_click_count,event_count)", "query_enabled": true},
    {"index": 3, "name": "hotel_detail_view_intensity", "block": "funnel", "raw_calculation": "bounded_log_intensity(hotel_detail_view_count,event_count)", "query_enabled": true},
