    {"index": 6, "name": "booking_cancel_intensity", "block": "funnel", "raw_calculation": "bounded_log_intensity(booking_cancel_count,event_count)", "query_enabled": false},
    {"index": 7, "name": "hotel_search_recency", "block": "funnel", "raw_calculation": "exp_decay(last_search_at,30d)", "query_enabled": false},
    {"index": 8, "name": "hotel_detail_recency", "block": "funnel", "raw_calculation": "exp_decay(last_detail_at,30d)", "query_enabled": false},
    {"index": 9, "name": "booking_start_recency", "block": "funnel", "raw_calculation": "exp_decay(last_booking_start_at,30d)", "query_enabled": false},
    {"index": 10, "name": "search_to_click_rate", "block": "funnel", "raw_calculation": "beta_smoothed_rate(hotel_click_count,hotel_search_count)", "query_enabled": false},
    {"index": 11, "name": "click_to_detail_rate", "block": "funnel", "raw_calculation": "beta_smoothed_rate(hotel_detail_view_count,hotel_click_count)", "query_enabled": false},
    {"index": 12, "name": "detail_to_booking_start_rate", "block": "funnel", "raw_calculation": "beta_smoothed_rate(booking_start_count,hotel_detail_view_count)", "query_enabled": false},
